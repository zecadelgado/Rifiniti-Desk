{
  "projeto": {
    "nome": "Rifiniti-Desk / NeoBenesys",
    "tipo": "Aplicativo desktop Python com PySide6 e PostgreSQL/Supabase",
    "arquivo_principal": "main.py",
    "descricao": "Sistema desktop para gestao de patrimonio, usuarios, fornecedores, centros de custo, setores/locais, notas fiscais, movimentacoes, manutencoes, depreciacao, auditoria, anexos e relatorios."
  },
  "requisitos_do_sistema": {
    "sistema_operacional_recomendado": "Windows 10 ou Windows 11",
    "python": {
      "versao_recomendada": "Python 3.11 ou superior",
      "instalacao": "Instale pelo site oficial python.org e marque a opcao Add Python to PATH durante a instalacao.",
      "verificar_instalacao": [
        "py --version",
        "python --version"
      ]
    },
    "postgresql": {
      "tipo": "PostgreSQL hospedado no Supabase",
      "porta": 5432,
      "database": "postgres",
      "observacao": "Configure DATABASE_URL ou POSTGRES_HOST/POSTGRES_USER/POSTGRES_PASSWORD no .env."
    }
  },
  "dependencias_python": {
    "arquivo": "requirements.txt",
    "bibliotecas": [
      "PySide6",
      "psycopg2-binary",
      "openpyxl",
      "bcrypt>=4.0.1"
    ]
  },
  "banco_de_dados": {
    "tipo": "PostgreSQL/Supabase",
    "arquivo_sql_principal": "database/data.sql",
    "script_de_preparo": "scripts/setup_database.py",
    "camada_de_compatibilidade": "backend/database/db_compat.py",
    "variaveis_no_env": [
      "DATABASE_URL",
      "POSTGRES_HOST",
      "POSTGRES_PORT",
      "POSTGRES_DB",
      "POSTGRES_USER",
      "POSTGRES_PASSWORD"
    ],
    "preparar_banco": ".\\.venv\\Scripts\\python.exe .\\scripts\\setup_database.py",
    "recriar_schema_public_do_zero": ".\\.venv\\Scripts\\python.exe .\\scripts\\setup_database.py --reset"
  },
  "usuario_inicial_do_sistema": {
    "quando_e_criado": "Criado automaticamente somente se a tabela usuarios estiver vazia e INITIAL_ADMIN_PASSWORD estiver definido.",
    "arquivo_responsavel": "backend/database/db_compat.py",
    "perfil": "master",
    "email": "Definido em .env como INITIAL_ADMIN_EMAIL",
    "senha": "Definida em .env como INITIAL_ADMIN_PASSWORD"
  },
  "testes_e_diagnostico": {
    "testar_conexao": ".\\.venv\\Scripts\\python.exe .\\scripts\\test_connection.py"
  },
  "arquivos_importantes": {
    "main.py": "Arquivo principal para abrir o aplicativo.",
    "requirements.txt": "Lista de bibliotecas Python.",
    "database/data.sql": "Schema PostgreSQL do projeto.",
    "scripts/setup_database.py": "Importa database/data.sql e aplica compatibilidade.",
    "scripts/test_connection.py": "Teste de conexao PostgreSQL.",
    "backend/database/config_db.py": "Configuracao principal de conexao PostgreSQL.",
    "backend/database/postgres_driver.py": "Adaptador de conexao/cursor PostgreSQL usado pelo app.",
    "backend/database/db_compat.py": "Ajustes automaticos do schema e usuario master inicial."
  }
